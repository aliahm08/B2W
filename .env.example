# Ollama or OpenAI-compatible chat endpoint used by the website assistant.
OLLAMA_BASE_URL="https://your-ollama-endpoint.example.com"
OLLAMA_API_KEY="your-ollama-api-key"
OLLAMA_MODEL="llama3.1:8b"

# Set to "openai" when the provider exposes /chat/completions instead of Ollama's /api/chat.
OLLAMA_API_STYLE="ollama"

# Google service account JSON for Calendar, Drive, and project-pipeline Sheets access.
GOOGLE_SERVICE_ACCOUNT_JSON='{"type":"service_account","project_id":"..."}'

# Optional override for the project pipeline Google Sheet ID.
# If omitted, the build reads the doc_id from the local index-projects.gsheet shortcut when present.
PROJECT_PIPELINE_SHEET_ID=""

# Only these calendars may be read for availability or written for bookings.
GOOGLE_ALLOWED_CALENDAR_IDS="primary,consultations@your-domain.com"
GOOGLE_BOOKING_CALENDAR_ID="consultations@your-domain.com"

# Internal attendees always added to booked consultations.
GOOGLE_INTERNAL_ATTENDEE_EMAILS="founder@b2w-ai.com"

# External guests are restricted to these allowlists.
GOOGLE_ALLOWED_ATTENDEE_EMAILS=""
GOOGLE_ALLOWED_ATTENDEE_DOMAINS="example.com"

# Only these Drive resources may be read into the assistant knowledge base.
GOOGLE_DRIVE_ALLOWED_FILE_IDS=""
GOOGLE_DRIVE_ALLOWED_FOLDER_IDS=""

# Consultation requests can optionally be written into this folder if it is also allowed above.
GOOGLE_DRIVE_BOOKING_FOLDER_ID=""

GOOGLE_BOOKING_TIMEZONE="America/New_York"
GOOGLE_BOOKING_LOOKAHEAD_DAYS="14"
GOOGLE_BOOKING_SLOT_MINUTES="60"
GOOGLE_BOOKING_START_HOUR="10"
GOOGLE_BOOKING_END_HOUR="17"

# Server-side project-page passwords. Set these in local env and Vercel project env vars.
PROJECT_ACCESS_SECRET="set-a-long-random-secret"
PROJECT_PASSWORD_BOREK_G="set-a-unique-password"
PROJECT_PASSWORD_BOREK_G_OPERATIONS="set-a-different-unique-password"
PROJECT_PASSWORD_UYGHUR_EATS="set-another-unique-password"
